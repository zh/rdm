#!/usr/bin/env ruby
# frozen_string_literal: true

lib = File.expand_path("../lib", __dir__)
$LOAD_PATH.unshift(lib) unless $LOAD_PATH.include?(lib)

require "rdm"

Rdm::Config.ensure_config_exists

begin
  Rdm::CLI.start(ARGV)
rescue Rdm::AuthError => e
  $stderr.puts e.message
  exit 2
rescue Rdm::ForbiddenError => e
  $stderr.puts e.message
  exit 2
rescue Rdm::NotFoundError => e
  $stderr.puts e.message
  exit 3
rescue Rdm::ValidationError => e
  $stderr.puts e.message
  exit 4
rescue Rdm::ConnectionError => e
  $stderr.puts e.message
  exit 1
rescue Rdm::TimeoutError => e
  $stderr.puts e.message
  exit 1
rescue Rdm::Error => e
  $stderr.puts "Error: #{e.message}"
  exit 1
rescue Interrupt
  $stderr.puts "\nAborted."
  exit 130
end
